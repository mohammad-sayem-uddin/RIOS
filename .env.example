# =============================================================================
# RIOS Environment Variables — Local Development
# Copy to .env and adjust values as needed
# =============================================================================

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rios
POSTGRES_PASSWORD=rios_password
POSTGRES_DB=rios
DATABASE_URL=postgresql://rios:rios_password@localhost:5432/rios

# EventStoreDB
EVENTSTORE_HOST=localhost
EVENTSTORE_HTTP_PORT=2113
EVENTSTORE_TCP_PORT=1113
EVENTSTORE_URL=http://localhost:2113

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333

# Application
NODE_ENV=development
API_PORT=3000
API_HOST=0.0.0.0
LOG_LEVEL=debug

# JWT (generate a strong secret for production)
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3001