{
  "name": "@rios/application",
  "version": "0.1.0",
  "private": true,
  "description": "RIOS Application Layer — commands, queries, handlers, use cases, DTOs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "dev": "tsc -b --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rios/domain": "workspace:*",
    "@rios/identity": "workspace:*",
    "@rios/shared": "workspace:*"
  },
  "devDependencies": {
    "@rios/typescript-config": "workspace:*",
    "typescript": "^5.6.3"
  }
}
