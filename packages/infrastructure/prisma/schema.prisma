  overallScore        Float    @default(0.0) @map("overall_score")
  conceptsJson        String?  @map("concepts_json") @db.Text
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([researcherProfileId])
  @@map("expertise_profiles")
}

model ResearchGapModel {
  id           String   @id @default(uuid()) @db.Uuid
  topic        String   @db.VarChar(255)
  field        String   @db.VarChar(255)
  description  String   @db.Text
  densityScore Float    @map("density_score")
  gapScore     Float    @map("gap_score")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([topic])
  @@map("research_gaps")
}






