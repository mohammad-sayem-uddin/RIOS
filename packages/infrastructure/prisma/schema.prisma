// Sprint 7 — Production Persistence Platform Prisma Schema
// Architecture Reference: Research Identity Domain & PostgreSQL Relational Schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PENDING
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  email        String      @unique @db.VarChar(255)
  passwordHash String      @map("password_hash") @db.Text
  displayName  String?     @map("display_name") @db.VarChar(255)
  status       UserStatus  @default(PENDING)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz

  roles             UserRole[]
  sessions          Session[]
  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]
  researchIdentities ResearchIdentity[]
  researchProfiles  ResearchProfile[]

  @@index([email])
  @@index([status])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users       UserRole[]
  permissions RolePermission[]

  @@index([name])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  roles RolePermission[]

  @@index([name])
  @@map("permissions")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz
  assignedBy String?  @map("assigned_by") @db.VarChar(255)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  grantedAt    DateTime @default(now()) @map("granted_at") @db.Timestamptz

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  deviceIp  String?   @map("device_ip") @db.VarChar(45)
  userAgent String?   @map("user_agent") @db.Text
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model RefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  tokenHash         String    @unique @map("token_hash") @db.Text
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz
  replacedByTokenId String?   @map("replaced_by_token_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  details   String?  @db.Text
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model ResearchIdentity {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  title           String   @db.VarChar(255)
  statement       String   @db.Text
  orcid           String?  @db.VarChar(50)
  googleScholarId String?  @map("google_scholar_id") @db.VarChar(100)
  researchAreas   String?  @map("research_areas") @db.Text
  researchGoals   String?  @map("research_goals") @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("research_identities")
}

// ─── Sprint 7 — Research Identity Domain Models ────────────────────────────────

model ResearchProfile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(255)
  headline  String?  @db.VarChar(255)
  biography String?  @db.Text
  summary   String?  @db.Text
  statement String?  @db.Text
  mission   String?  @db.Text
  vision    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  education        Education[]
  experience       ProfessionalExperience[]
  interests        ResearchInterest[]
  skills           Skill[]
  externalProfiles ExternalProfile[]
  portfolioAssets  PortfolioAsset[]
  publications     Publication[]
  researchProjects ResearchProject[]

  @@index([userId])
  @@map("research_profiles")
}

model Education {
  id           String    @id @default(uuid()) @db.Uuid
  profileId    String    @map("profile_id") @db.Uuid
  institution  String    @db.VarChar(255)
  degree       String    @db.VarChar(255)
  fieldOfStudy String    @map("field_of_study") @db.VarChar(255)
  startDate    DateTime  @map("start_date") @db.Timestamptz
  endDate      DateTime? @map("end_date") @db.Timestamptz
  isCurrent    Boolean   @default(false) @map("is_current")
  grade        String?   @db.VarChar(100)
  description  String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  profile ResearchProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("educations")
}

model ProfessionalExperience {
  id            String    @id @default(uuid()) @db.Uuid
  profileId     String    @map("profile_id") @db.Uuid
  positionTitle String    @map("position_title") @db.VarChar(255)
  organization  String    @db.VarChar(255)
  location      String?   @db.VarChar(255)
  startDate     DateTime  @map("start_date") @db.Timestamptz
  endDate       DateTime? @map("end_date") @db.Timestamptz
  isCurrent     Boolean   @default(false) @map("is_current")
  description   String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  profile ResearchProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("professional_experiences")
}

model ResearchInterest {
  id        String   @id @default(uuid()) @db.Uuid
  profileId String   @map("profile_id") @db.Uuid
  name      String   @db.VarChar(150)
  category  String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  profile ResearchProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([name])
  @@map("research_interests")
}

model Skill {
  id               String   @id @default(uuid()) @db.Uuid
  profileId        String   @map("profile_id") @db.Uuid
  name             String   @db.VarChar(100)
  category         String   @db.VarChar(100)
  proficiencyLevel String?  @map("proficiency_level") @db.VarChar(50)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  profile ResearchProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([name])
  @@map("skills")
}

model ExternalProfile {
  id                 String   @id @default(uuid()) @db.Uuid
  profileId          String   @map("profile_id") @db.Uuid
  provider           String   @db.VarChar(100)
  url                String   @db.Text
  externalIdentifier String?  @map("external_identifier") @db.VarChar(255)
  isVerified         Boolean  @default(false) @map("is_verified")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  profile ResearchProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("external_profiles")
}

model PortfolioAsset {
  id            String   @id @default(uuid()) @db.Uuid
  profileId     String   @map("profile_id") @db.Uuid
  title         String   @db.VarChar(255)
  assetType     String   @map("asset_type") @db.VarChar(100)
  fileUrl       String   @map("file_url") @db.Text
  mimeType      String   @map("mime_type") @db.VarChar(100)
  fileSizeBytes Int      @map("file_size_bytes")
  uploadedAt    DateTime @default(now()) @map("uploaded_at") @db.Timestamptz

  profile ResearchProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("portfolio_assets")
}

// ─── Sprint 8 — Publications & Research Projects Models ─────────────────────

enum PublicationType {
  JOURNAL_ARTICLE
  CONFERENCE_PAPER
  BOOK
  BOOK_CHAPTER
  THESIS
  TECHNICAL_REPORT
  PREPRINT
}

enum PublicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  PUBLISHED
  PREPRINT
}

enum ProjectRole {
  PRINCIPAL_INVESTIGATOR
  CO_INVESTIGATOR
  RESEARCHER
  POSTDOC
  STUDENT_RESEARCHER
  COLLABORATOR
}

enum VenueType {
  JOURNAL
  CONFERENCE
  OTHER
}

model Publisher {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(255)
  location   String?  @db.VarChar(255)
  websiteUrl String?  @map("website_url") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  venues       Venue[]
  publications Publication[]

  @@map("publishers")
}

model Venue {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(255)
  venueType   VenueType @map("venue_type")
  issn        String?   @db.VarChar(50)
  isbn        String?   @db.VarChar(50)
  publisherId String?   @map("publisher_id") @db.Uuid
  url         String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  publisher    Publisher?    @relation(fields: [publisherId], references: [id], onDelete: SetNull)
  publications Publication[]

  @@index([name])
  @@map("venues")
}

model Publication {
  id            String            @id @default(uuid()) @db.Uuid
  profileId     String            @map("profile_id") @db.Uuid
  title         String            @db.VarChar(500)
  type          PublicationType
  status        PublicationStatus @default(DRAFT)
  doi           String?           @unique @db.VarChar(255)
  isbn          String?           @db.VarChar(50)
  abstract      String?           @db.Text
  keywords      String?           @db.Text
  year          Int?
  citationCount Int               @default(0) @map("citation_count")
  url           String?           @db.Text
  language      String?           @db.VarChar(50)
  venueId       String?           @map("venue_id") @db.Uuid
  publisherId   String?           @map("publisher_id") @db.Uuid
  submittedDate DateTime?         @map("submitted_date") @db.Timestamptz
  acceptedDate  DateTime?         @map("accepted_date") @db.Timestamptz
  publishedDate DateTime?         @map("published_date") @db.Timestamptz
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  profile   ResearchProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  venue     Venue?          @relation(fields: [venueId], references: [id], onDelete: SetNull)
  publisher Publisher?      @relation(fields: [publisherId], references: [id], onDelete: SetNull)
  authors   Author[]
  fundings  Funding[]

  @@index([profileId])
  @@index([title])
  @@index([doi])
  @@index([status])
  @@map("publications")
}

model Author {
  id              String   @id @default(uuid()) @db.Uuid
  publicationId   String   @map("publication_id") @db.Uuid
  name            String   @db.VarChar(255)
  email           String?  @db.VarChar(255)
  orcid           String?  @db.VarChar(50)
  authorOrder     Int      @map("author_order")
  isCorresponding Boolean  @default(false) @map("is_corresponding")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  publication  Publication           @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  affiliations AffiliationSnapshot[]

  @@index([publicationId])
  @@map("authors")
}

model AffiliationSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  authorId    String   @map("author_id") @db.Uuid
  institution String   @db.VarChar(255)
  department  String?  @db.VarChar(255)
  location    String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@map("affiliation_snapshots")
}

model Funding {
  id                String   @id @default(uuid()) @db.Uuid
  publicationId     String   @map("publication_id") @db.Uuid
  funderName        String   @map("funder_name") @db.VarChar(255)
  fundingIdentifier String?  @map("funding_identifier") @db.VarChar(100)
  grantTitle        String?  @map("grant_title") @db.VarChar(255)
  amountCurrency    String?  @map("amount_currency") @db.VarChar(10)
  amountValue       Float?   @map("amount_value")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  publication Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  @@index([publicationId])
  @@map("fundings")
}

model ResearchProject {
  id              String        @id @default(uuid()) @db.Uuid
  profileId       String        @map("profile_id") @db.Uuid
  title           String        @db.VarChar(255)
  description     String        @db.Text
  status          String        @default("ACTIVE") @db.VarChar(50)
  startDate       DateTime      @map("start_date") @db.Timestamptz
  endDate         DateTime?     @map("end_date") @db.Timestamptz
  grantIdentifier String?       @map("grant_identifier") @db.VarChar(100)
  fundingAgency   String?       @map("funding_agency") @db.VarChar(255)
  budget          Float?
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  profile ResearchProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  members ProjectMember[]

  @@index([profileId])
  @@map("research_projects")
}

model ProjectMember {
  id        String      @id @default(uuid()) @db.Uuid
  projectId String      @map("project_id") @db.Uuid
  profileId String?     @map("profile_id") @db.Uuid
  name      String      @db.VarChar(255)
  role      ProjectRole
  startDate DateTime    @map("start_date") @db.Timestamptz
  endDate   DateTime?   @map("end_date") @db.Timestamptz
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz

  project ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_members")
}

